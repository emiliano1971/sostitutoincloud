<?xml version="1.0" encoding="UTF-8"?>
<!--
    log4j2.xml — Configurazione unica per tutti gli ambienti.
    Le proprietà @log.level@, @deploy.env@, @console.threshold@ sono sostituite
    da Maven filtering al momento della build (delimiter @...@ di Spring Boot parent).

    Dopo filtering, i valori diventano letterali:
      local:      log.level=DEBUG  console.threshold=ALL   → console + file
      test/prod:  log.level=INFO   console.threshold=OFF   → solo file
-->
<Configuration status="WARN">

    <Properties>
        <Property name="logLevel">@log.level@</Property>
        <Property name="logFile">${sys:catalina.home}/logs/sostitutoincloud-@deploy.env@.log</Property>
        <Property name="logPattern">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
        <Property name="consoleThreshold">@console.threshold@</Property>
    </Properties>

    <Appenders>
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <ThresholdFilter level="${consoleThreshold}" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="${logPattern}"/>
        </Console>

        <RollingFile name="FileAppender"
                     fileName="${logFile}"
                     filePattern="${sys:catalina.home}/logs/sostitutoincloud-@deploy.env@-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="${logPattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
            </Policies>
            <DefaultRolloverStrategy>
                <Delete basePath="logs" maxDepth="1">
                    <IfFileName glob="sostitutoincloud-@deploy.env@-*.log.gz"/>
                    <IfLastModified age="30d"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="${logLevel}">
            <AppenderRef ref="FileAppender"/>
            <AppenderRef ref="ConsoleAppender"/>
        </Root>
    </Loggers>

</Configuration>
