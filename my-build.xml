<?xml version="1.0" encoding="UTF-8"?>
<!--
    my-build.xml — Deploy locale nel progetto Tomcat
    =====================================================
    Eseguito da maven-antrun-plugin nella fase package.
    Parametri passati da pom.xml:
      project.basedir              root del progetto (= webapps/sostitutoincloud/)
      project.build.directory      cartella target/
      project.build.outputDirectory cartella target/classes/
      deploy.env                   profilo attivo (local | test | prod)
      db.properties.source         file properties DB per ambiente
      log4j.source                 file Log4j2 (sempre log4j2.xml)
-->
<project name="sostitutoincloud-deploy" default="deploy">

    <target name="deploy">

        <!-- ── Condizioni ambiente ──
             is.local.env = true solo quando deploy.env=local.
             In test/prod la copia di config.json e del frontend nella root
             della webapp NON deve avvenire: il WAR è l'unico artefatto. -->
        <condition property="is.local.env">
            <equals arg1="${deploy.env}" arg2="local"/>
        </condition>
        <!-- copy.frontend.local = local AND frontend/dist presente -->
        <condition property="copy.frontend.local">
            <and>
                <equals arg1="${deploy.env}" arg2="local"/>
                <available file="${project.basedir}/frontend/dist" type="dir"/>
            </and>
        </condition>

        <echo message="[my-build] Deploy ambiente: ${deploy.env}"/>
        <echo message="[my-build] DB properties:   ${db.properties.source}"/>

        <!-- ── 1. Cancella e ricrea WEB-INF/classes/ ── -->
        <delete dir="${project.basedir}/WEB-INF/classes" quiet="true"/>
        <mkdir  dir="${project.basedir}/WEB-INF/classes"/>

        <!-- ── 2. Copia classi compilate da target/classes/ → WEB-INF/classes/ ── -->
        <copy todir="${project.basedir}/WEB-INF/classes" overwrite="true">
            <fileset dir="${project.build.outputDirectory}">
                <include name="**/*.class"/>
            </fileset>
        </copy>

        <!--
            ── 3. Copia risorse da src/main/resources/ → WEB-INF/classes/ ──
            Esclude i file ambiente-specifici (db-*.properties) gestiti al passo 6.
            Esclude i file log4j2*.xml gestiti al passo 7 (serve la versione filtrata).
        -->
        <copy todir="${project.basedir}/WEB-INF/classes" overwrite="true">
            <fileset dir="${project.basedir}/src/main/resources">
                <exclude name="db-*.properties"/>
                <exclude name="log4j2*.xml"/>
            </fileset>
        </copy>

        <!-- ── 4. Pulisce e ricopia JAR da target/lib/ → WEB-INF/lib/ ── -->
        <delete dir="${project.basedir}/WEB-INF/lib" quiet="true"/>
        <mkdir  dir="${project.basedir}/WEB-INF/lib"/>
        <copy todir="${project.basedir}/WEB-INF/lib" overwrite="true">
            <fileset dir="${project.build.directory}/lib">
                <include name="*.jar"/>
            </fileset>
        </copy>

        <!-- ── 5. Copia web.xml da src/main/webapp/WEB-INF/ ── -->
        <copy todir="${project.basedir}/WEB-INF"
              file="${project.basedir}/src/main/webapp/WEB-INF/web.xml"
              failonerror="false"
              overwrite="true"/>

        <!--
            ── 6. Copia il file DB properties per ambiente → WEB-INF/classes/db.properties ──
            Il nome del file sorgente è determinato dalla proprietà db.properties.source.
        -->
        <copy tofile="${project.basedir}/WEB-INF/classes/db.properties"
              file="${project.basedir}/src/main/resources/${db.properties.source}"
              overwrite="true"/>

        <!--
            ── 7. Copia il file Log4j2 filtrato → WEB-INF/classes/log4j2.xml ──
            Usa la versione in target/classes/ dove Maven ha già sostituito @log.level@
            e @deploy.env@ con i valori del profilo corrente.
        -->
        <copy tofile="${project.basedir}/WEB-INF/classes/log4j2.xml"
              file="${project.build.outputDirectory}/${log4j.source}"
              overwrite="true"/>

        <!-- ── 8. Copia config.{env}.json → WEB-INF/classes/static/config.json ──
             SOLO in local. In test/prod il config.json viene gestito dal pom.xml
             (copia + rinomina di config.{env}.json in target/classes/static/). -->
        <antcall target="copy-config"/>

        <!--
            ── 9. Copia frontend buildato (frontend/dist/) → root webapp Tomcat ──
            SOLO in local. Il frontend React viene copiato nella stessa webapp del
            backend (project.basedir = webapps/sostitutoincloud/), servito da Tomcat.
            In test/prod il frontend è già dentro il WAR (target/classes/static/) —
            NON va copiato nella root, che è il sorgente locale.
        -->
        <antcall target="copy-frontend"/>
        <antcall target="warn-no-frontend"/>

        <echo message="[my-build] Deploy completato in WEB-INF/"/>

    </target>

    <!-- Copia config.{env}.json → WEB-INF/classes/static/config.json (solo local) -->
    <target name="copy-config" if="is.local.env">
        <echo message="[my-build] Copia config.${deploy.env}.json → WEB-INF/classes/static/config.json"/>
        <copy tofile="${project.basedir}/WEB-INF/classes/static/config.json"
              file="${project.basedir}/frontend/public/config.${deploy.env}.json"
              overwrite="true"
              failonerror="false"/>
    </target>

    <!-- Copia il frontend buildato nella root della webapp (escluso WEB-INF/) — solo local -->
    <target name="copy-frontend" if="copy.frontend.local">
        <echo message="[my-build] Copia frontend da frontend/dist/ → ${project.basedir}/"/>
        <copy todir="${project.basedir}" overwrite="true">
            <fileset dir="${project.basedir}/frontend/dist">
                <exclude name="WEB-INF/**"/>
                <exclude name="config*.json"/>
            </fileset>
        </copy>
        <echo message="[my-build] Frontend copiato nella root della webapp."/>
    </target>

    <!-- Avviso quando, in local, il frontend non è stato buildato -->
    <target name="warn-no-frontend" if="is.local.env" unless="copy.frontend.local">
        <echo level="warning"
              message="[my-build] WARNING: frontend/dist/ non trovato — frontend non buildato. Salto la copia del frontend (esegui 'cd frontend &amp;&amp; npm run build')."/>
    </target>

</project>
